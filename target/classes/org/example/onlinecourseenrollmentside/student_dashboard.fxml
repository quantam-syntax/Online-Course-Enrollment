<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="org.example.onlinecourseenrollmentside.controller.StudentController"
        stylesheets="@style.css"
        styleClass="dashboard-root"
        spacing="14">

    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <!-- Top bar -->
    <HBox alignment="CENTER_LEFT" styleClass="topbar">
        <VBox HBox.hgrow="ALWAYS" spacing="2">
            <Label text="Student Dashboard" styleClass="page-title"/>
            <Label fx:id="welcomeLabel" styleClass="page-subtitle"/>
        </VBox>
        <Button text="Logout" onAction="#handleLogout" styleClass="btn-logout"/>
    </HBox>

    <!-- Enroll card -->
    <VBox styleClass="section-card" spacing="10">
        <Label text="Enroll in a Course" styleClass="section-title"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <ComboBox fx:id="coursesCombo" promptText="Select a course to enroll"
                      styleClass="form-combo" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button text="Enroll" onAction="#handleEnroll" styleClass="btn-primary"/>
            <Button text="Refresh" onAction="#handleRefresh" styleClass="btn-ghost"/>
        </HBox>
    </VBox>

    <!-- Department enrollment card -->
    <VBox styleClass="section-card" spacing="10">
        <Label text="Enroll in a Department" styleClass="section-title"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <ComboBox fx:id="departmentsCombo" promptText="Select a department"
                      styleClass="form-combo" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button text="Enroll Department" onAction="#handleEnrollDepartment" styleClass="btn-primary"/>
        </HBox>
    </VBox>

    <!-- My Enrollments card -->
    <VBox styleClass="section-card" spacing="8" VBox.vgrow="ALWAYS">
        <Label text="My Enrollments" styleClass="section-title"/>
        <ListView fx:id="enrollmentsList" styleClass="data-list" VBox.vgrow="ALWAYS" prefHeight="200"/>
    </VBox>

    <!-- Fee + actions card -->
    <VBox styleClass="section-card" spacing="10">
        <HBox alignment="CENTER_LEFT" spacing="14">
            <VBox HBox.hgrow="ALWAYS" spacing="4">
                <Label text="Pending Fees" styleClass="field-label"/>
                <Label fx:id="feeLabel" styleClass="fee-label"/>
            </VBox>
            <Button text="Pay Fees" onAction="#handlePayFees" styleClass="btn-pay"/>
        </HBox>
    </VBox>

    <!-- Status bar -->
    <Label fx:id="statusLabel" styleClass="status-label" wrapText="true"/>

</VBox>