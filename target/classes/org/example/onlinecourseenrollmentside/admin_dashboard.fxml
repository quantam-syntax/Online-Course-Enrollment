<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="org.example.onlinecourseenrollmentside.controller.AdminController"
        stylesheets="@style.css"
        styleClass="dashboard-root"
        spacing="14">

    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <!-- Top bar -->
    <HBox alignment="CENTER_LEFT" styleClass="topbar">
        <VBox HBox.hgrow="ALWAYS" spacing="2">
            <Label text="Admin Dashboard" styleClass="page-title"/>
            <Label text="Manage students and courses" styleClass="page-subtitle"/>
        </VBox>
        <Button text="Logout" onAction="#handleLogout" styleClass="btn-logout"/>
    </HBox>

    <!-- Add Student card -->
    <VBox styleClass="section-card" spacing="10">
        <Label text="Add New Student" styleClass="section-title"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="studentIdField" promptText="Student ID" styleClass="form-field" prefWidth="120"/>
            <TextField fx:id="studentNameField" promptText="Full Name" styleClass="form-field" HBox.hgrow="ALWAYS"/>
            <Button text="Add Student" onAction="#handleAddStudent" styleClass="btn-primary"/>
        </HBox>
    </VBox>

    <!-- Add Instructor card -->
    <VBox styleClass="section-card" spacing="10">
        <Label text="Add New Instructor" styleClass="section-title"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="instructorIdField" promptText="Instructor ID" styleClass="form-field" prefWidth="140"/>
            <TextField fx:id="instructorNameField" promptText="Instructor Name" styleClass="form-field" HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="instructorDepartmentCombo" promptText="Department" styleClass="form-combo" prefWidth="180"/>
            <ComboBox fx:id="instructorCourseCombo" promptText="Course" styleClass="form-combo" prefWidth="220"/>
            <Button text="Add Instructor" onAction="#handleAddInstructor" styleClass="btn-primary"/>
        </HBox>
        <ListView fx:id="instructorsList" styleClass="data-list" prefHeight="120"/>
        <HBox spacing="8">
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Delete Selected Instructor" onAction="#handleDeleteInstructor" styleClass="btn-danger"/>
        </HBox>
    </VBox>

    <!-- Add Department card -->
    <VBox styleClass="section-card" spacing="10">
        <Label text="Add New Department" styleClass="section-title"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="departmentNameField" promptText="Department Name" styleClass="form-field" HBox.hgrow="ALWAYS"/>
            <Button text="Add Department" onAction="#handleAddDepartment" styleClass="btn-primary"/>
        </HBox>
        <ListView fx:id="departmentsList" styleClass="data-list" prefHeight="120"/>
        <HBox spacing="8">
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Delete Selected Department" onAction="#handleDeleteDepartment" styleClass="btn-danger"/>
        </HBox>
    </VBox>

    <!-- Add Course card -->
    <VBox styleClass="section-card" spacing="10">
        <Label text="Add New Course" styleClass="section-title"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="courseIdField" promptText="Course ID" styleClass="form-field" prefWidth="100"/>
            <TextField fx:id="courseTitleField" promptText="Course Title" styleClass="form-field" HBox.hgrow="ALWAYS"/>
            <TextField fx:id="courseFeeField" promptText="Fee (₹)" styleClass="form-field" prefWidth="90"/>
            <TextField fx:id="courseDayField" promptText="Day" styleClass="form-field" prefWidth="110"/>
            <TextField fx:id="courseTimeField" promptText="Time" styleClass="form-field" prefWidth="110"/>
            <ComboBox fx:id="courseDepartmentCombo" promptText="Department" styleClass="form-combo" prefWidth="180"/>
            <ComboBox fx:id="courseInstructorCombo" promptText="Instructor (optional)" styleClass="form-combo" prefWidth="180"/>
            <Button text="Add Course" onAction="#handleAddCourse" styleClass="btn-primary"/>
        </HBox>
    </VBox>

    <!-- Lists row -->
    <HBox spacing="14" VBox.vgrow="ALWAYS">

        <!-- Students list card -->
        <VBox styleClass="section-card" spacing="8" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <Label text="Students" styleClass="section-title" HBox.hgrow="ALWAYS"/>
            </HBox>
            <ListView fx:id="studentsList" styleClass="data-list" VBox.vgrow="ALWAYS" prefHeight="200"/>
            <HBox spacing="8">
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Delete Selected Student" onAction="#handleDeleteStudent" styleClass="btn-danger"/>
            </HBox>
        </VBox>

        <!-- Courses list card -->
        <VBox styleClass="section-card" spacing="8" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <Label text="Courses" styleClass="section-title" HBox.hgrow="ALWAYS"/>
            </HBox>
            <ListView fx:id="coursesList" styleClass="data-list" VBox.vgrow="ALWAYS" prefHeight="200"/>
            <HBox spacing="8">
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Delete Selected Course" onAction="#handleDeleteCourse" styleClass="btn-danger"/>
            </HBox>
        </VBox>

    </HBox>

    <!-- Status bar -->
    <Label fx:id="statusLabel" styleClass="status-label" wrapText="true"/>

</VBox>